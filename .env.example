# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only: morning report PDF uploads + cron (bypasses storage RLS). From Supabase → Settings → API.
SUPABASE_SERVICE_ROLE_KEY=

# App URL (optional – used for WhatsApp order link in notifications)
# Defaults to https://sunkool-management.vercel.app if not set
# NEXT_PUBLIC_APP_URL=https://sunkool-management.vercel.app

# Sentry (optional but recommended for production error monitoring)
NEXT_PUBLIC_SENTRY_DSN=

# Cron secret (used to protect /api/cron/* endpoints from unauthorized calls)
CRON_SECRET=your-random-secret-here
